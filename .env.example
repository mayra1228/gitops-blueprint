DATABASE_URL=postgresql+asyncpg://gitops:gitops_dev@db:5432/gitops_platform
DATABASE_URL_SYNC=postgresql://gitops:gitops_dev@db:5432/gitops_platform
JWT_SECRET=dev-secret-change-in-production
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=webhook-secret
DEMO_DATA_ROOT=/demo_data
# K8S integration (optional — set KUBECONFIG_PATH to enable K8S execution)
KUBECONFIG_PATH=
K8S_CONTEXT=
K8S_EXECUTION_MODE=sandbox
K8S_NAMESPACE_ALLOWLIST=sandbox,default
K8S_ALLOWED_CLUSTER=kind-gitops-sandbox
